# Ignorar todo o core do Moodle - rastrear apenas customizações
/*

# Customizações a rastrear
!auth/
!theme/
!repository-altimus/
!.gitignore

# Dentro de auth, ignorar tudo exceto altimus
auth/*
!auth/altimus/

# Dentro de theme, ignorar tudo exceto moove
theme/*
!theme/moove/

# Arquivos sensíveis
config.php
*.log
error_log
.DS_Store
node_modules/
